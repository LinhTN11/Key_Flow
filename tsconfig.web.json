{
    "compilerOptions": {
        "composite": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "outDir": "./out",
        "rootDir": "./src",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": false,
        "target": "ESNext",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "node"
        ],
        "resolveJsonModule": true,
        "declaration": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/renderer/*"
            ]
        }
    },
    "include": [
        "src/renderer/**/*.ts",
        "src/renderer/**/*.tsx",
        "src/renderer/**/*.json"
    ]
}